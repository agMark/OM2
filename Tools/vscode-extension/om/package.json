{
  "name": "om",
  "displayName": "OM",
  "description": "Navigation, cross-model comparison, and authoring helpers for the Air Tractor Owner's Manual repo",
  "version": "0.2.0",
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
        "activitybar": [
            {
                "id": "myCustomExplorer",
                "title": "My Custom Explorer",
                "icon": "resources/my-icon.svg"
            }
        ]
    },
    "views": {
        "myCustomExplorer": [
            {
                "id": "myTreeView",
                "name": "My Tree View",
                "icon": "resources/my-icon.svg"
            },
            {
                "id": "imageSourceView",
                "name": "Image Sources",
                "icon": "resources/my-icon.svg"
            }
        ]
    },
    "commands": [
        {
            "command": "om.refresh",
            "title": "OM: Refresh",
            "icon": "$(refresh)"
        },
        {
            "command": "om.compareModelFiles",
            "title": "OM: Compare Model Files..."
        },
        {
            "command": "om.insertXrefForSection",
            "title": "OM: Insert Xref to This Section"
        },
        {
            "command": "om.insertStyleClass",
            "title": "OM: Insert Style Class..."
        },
        {
            "command": "om.insertXref",
            "title": "OM: Insert Xref..."
        },
        {
            "command": "om.showPreview",
            "title": "OM: Show Preview",
            "icon": "$(open-preview)"
        },
        {
            "command": "om.showPreviewToSide",
            "title": "OM: Show Preview to the Side",
            "icon": "$(open-preview)"
        },
        {
            "command": "om.preview.toggleSingleFragment",
            "title": "OM: Toggle Single-Fragment Preview Mode"
        },
        {
            "command": "om.compareAllModelsPreview",
            "title": "OM: Compare All Models in Preview"
        },
        {
            "command": "om.insertFigure",
            "title": "OM: Insert Figure..."
        },
        {
            "command": "om.insertBox",
            "title": "OM: Insert Caution/Warning Box..."
        },
        {
            "command": "om.openImageInExternalEditor",
            "title": "OM: Reveal Image in File Explorer (for Open With...)"
        },
        {
            "command": "om.refreshImageSources",
            "title": "OM: Refresh Image Sources",
            "icon": "$(refresh)"
        },
        {
            "command": "om.linkImageToSource",
            "title": "OM: Link Image to Source File..."
        },
        {
            "command": "om.openImageSource",
            "title": "OM: Open Source in File Explorer"
        },
        {
            "command": "om.removeImageSourceLink",
            "title": "OM: Remove Source Link..."
        },
        {
            "command": "om.linkCurrentImageToSource",
            "title": "OM: Link Current Image to Source File..."
        }
    ],
    "menus": {
        "view/title": [
            {
                "command": "om.refresh",
                "when": "view == myTreeView",
                "group": "navigation"
            },
            {
                "command": "om.refreshImageSources",
                "when": "view == imageSourceView",
                "group": "navigation"
            },
            {
                "command": "om.linkImageToSource",
                "when": "view == imageSourceView",
                "group": "navigation"
            }
        ],
        "view/item/context": [
            {
                "command": "om.compareModelFiles",
                "when": "view == myTreeView && viewItem == divergentSection",
                "group": "inline"
            },
            {
                "command": "om.compareAllModelsPreview",
                "when": "view == myTreeView && viewItem == divergentSection"
            },
            {
                "command": "om.insertXrefForSection",
                "when": "view == myTreeView && viewItem =~ /^(merged|divergentSection)$/"
            },
            {
                "command": "om.linkImageToSource",
                "when": "view == imageSourceView && viewItem =~ /^(unlinkedImage|linkedImage|sourceFile)$/"
            },
            {
                "command": "om.openImageSource",
                "when": "view == imageSourceView && viewItem == linkedImage"
            },
            {
                "command": "om.removeImageSourceLink",
                "when": "view == imageSourceView && viewItem == linkedImage"
            }
        ],
        "editor/context": [
            {
                "command": "om.insertStyleClass",
                "when": "resourceLangId == html",
                "group": "om"
            },
            {
                "command": "om.insertXref",
                "when": "resourceLangId == html",
                "group": "om"
            },
            {
                "command": "om.insertFigure",
                "when": "resourceLangId == html",
                "group": "om"
            },
            {
                "command": "om.insertBox",
                "when": "resourceLangId == html",
                "group": "om"
            },
            {
                "command": "om.openImageInExternalEditor",
                "when": "resourceLangId == html",
                "group": "om"
            },
            {
                "command": "om.linkCurrentImageToSource",
                "when": "resourceLangId == html",
                "group": "om"
            }
        ],
        "editor/title": [
            {
                "command": "om.showPreviewToSide",
                "when": "resourceLangId == html",
                "group": "navigation"
            }
        ]
    },
    "configuration": {
        "title": "OM",
        "properties": {
            "om.preview.contentWidthIn": {
                "type": "number",
                "default": 6.5,
                "description": "Approximate printed page content width (in inches) used to size the in-editor styled preview. css/pagedjs.css doesn't declare an explicit @page size, so this is an editable approximation."
            }
        }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.105.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "eslint": "^9.36.0",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2"
  }
}
